# Image versions — pin to a specific tag in production (e.g. 1.2.0)
CONLUZ_API_VERSION=latest
CONLUZ_WEB_VERSION=latest

# Ports exposed on the host
CONLUZ_API_PORT=8080
CONLUZ_WEB_PORT=80

# PostgreSQL
POSTGRES_DB=conluz
POSTGRES_USER=conluz
POSTGRES_PASSWORD=changeme

# InfluxDB 1.8
INFLUXDB_DB=conluz
INFLUXDB_USER=admin
INFLUXDB_PASSWORD=changeme
INFLUXDB_PORT=8086
