# IP or hostname of the machine running the MQTT broker
MQTT_BROKER_HOST=192.168.1.x
MQTT_BROKER_PORT=1883

# MQTT topics to subscribe — comma-separated, wildcards supported (# = all)
MQTT_TOPICS=#

# IP or hostname of the machine running the app role (InfluxDB)
INFLUXDB_HOST=192.168.1.x
INFLUXDB_PORT=8086
INFLUXDB_DB=conluz
INFLUXDB_USER=admin
INFLUXDB_PASSWORD=changeme
