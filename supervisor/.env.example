# Full URL to Prometheus, reachable from the Grafana container
PROMETHEUS_URL=http://192.168.1.x:9090

# Full URL to Loki, reachable from the Grafana container
LOKI_URL=http://192.168.1.x:3100

# Grafana admin credentials
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=changeme

# Public root URL (used in alert links and share links)
GF_SERVER_ROOT_URL=http://%(domain)s:3000
