# Copy to .env and fill in. NEVER commit the real .env.

# --- Used by export-from-grafana.py (read from the Grafana API) ---
# Create a service account token on the remote Grafana: Administration > Service accounts
# > Add service account (role: Admin, needed to list datasources) > Add token.
GRAFANA_URL=http://<remote-grafana-host-ip>:3000
GRAFANA_TOKEN=<service-account-token>

# --- Injected into the local Grafana datasources at runtime ---
# Point INFLUXDB_URL at either:
#   (a) the InfluxDB host IP:  http://<remote-influxdb-ip>:8086
#   (b) a local InfluxDB you run yourself:  http://host.docker.internal:8086
INFLUXDB_URL=http://<remote-influxdb-ip>:8086
# InfluxDB v1 credentials (InfluxQL datasource auth). USER is the DB user; do NOT use a v2 token here.
INFLUXDB_USER=<influxdb-v1-user>
INFLUXDB_PASSWORD=<influxdb-v1-password-if-applicable>

# --- Local Grafana admin login ---
GF_ADMIN_PASSWORD=admin
